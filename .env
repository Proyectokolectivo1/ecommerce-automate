# Base de datos
# SQLite (desarrollo):
DATABASE_URL=file:/home/z/my-project/db/custom.db
# PostgreSQL (producción):
# DATABASE_URL=postgresql://ecommerce:ecommerce_dev_password@localhost:5432/ecommerce

# NextAuth
NEXTAUTH_SECRET=dev-secret-ecommerce-platform-2024
# NEXTAUTH_URL=https://your-domain.com  # En producción

# Realtime service (socket.io mini-service puerto 3003)
REALTIME_URL=http://localhost:3003/emit
REALTIME_SECRET=dev-realtime-secret

# Oracle Cloud Object Storage (S3-compatible)
# Si no se configuran, se usa almacenamiento local automáticamente.
# ORACLE_CLOUD_NAMESPACE=mi-namespace
# ORACLE_CLOUD_REGION=us-ashburn-1
# ORACLE_CLOUD_BUCKET=ecommerce-automate
# ORACLE_CLOUD_ACCESS_KEY=ak...
# ORACLE_CLOUD_SECRET_KEY=sj...

# Redis (colas BullMQ — opcional)
# Si no se configura, se usan colas en memoria (setInterval).
# REDIS_URL=redis://localhost:6379

# n8n (automatizaciones auxiliares — opcional)
# N8N_URL=http://localhost:5678

# Configuración de la aplicación
# NODE_ENV=production
# PORT=3000
