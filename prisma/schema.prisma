// ============================================================
// Plataforma Ecommerce Inteligente - Schema Prisma
// ============================================================
// Nota: SQLite no soporta enums nativos ni arrays. Se usan String
// con validación Zod en la capa de aplicación. Al migrar a Postgres
// estos campos pueden convertirse a enums sin cambiar la lógica.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// Sección 14-15: Autenticación, Roles y Permisos
// ============================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String
  role          String   @default("SERVICIO") // ADMIN | GERENCIA | BODEGA | SERVICIO
  active        Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  auditLogs     AuditLog[]
  notifications Notification[]
}

// ============================================================
// Sección 11: CRM Clientes
// ============================================================

model Customer {
  id            String   @id @default(cuid())
  shopifyId     String?  @unique
  name          String
  email         String?
  phone         String?
  city          String?
  address       String?
  classification String  @default("NUEVO") // VIP | FRECUENTE | NUEVO | INACTIVO
  totalSpent    Float    @default(0)
  ordersCount   Int      @default(0)
  lastOrderAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]
}

// ============================================================
// Catálogo: Productos (sincronizado Shopify)
// ============================================================

model Product {
  id            String   @id @default(cuid())
  shopifyId     String?  @unique
  sku           String?  @unique
  title         String
  variant       String?
  cost          Float    @default(0)   // costo unitario
  price         Float    @default(0)   // precio venta
  weight        Float    @default(0)   // gramos
  inventoryQty  Int      @default(0)
  imageUrl      String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems    OrderItem[]
  returns       Return[]
}

// ============================================================
// Sección 7: Pedidos + FSM de 8 estados
// ============================================================

model Order {
  id              String   @id @default(cuid())
  shopifyId       String?  @unique
  orderNumber     String   @unique
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  status          String   @default("NUEVO")
  // NUEVO | PENDIENTE_PAGO_TRANSPORTE | PAGO_TRANSPORTE_CONFIRMADO
  // PREPARANDO | ENVIADO | ENTREGADO | DEVUELTO | CANCELADO
  paymentMethod   String   @default("PREPAID") // PREPAID | COD
  subtotal        Float    @default(0)
  shippingCost    Float    @default(0)   // cobrado al cliente
  transportCost   Float    @default(0)   // costo real transporte
  total           Float    @default(0)
  declaredValue   Float    @default(0)
  city            String?
  address         String?
  notes           String?
  codPaid         Boolean  @default(false) // pago de transporte confirmado
  codPaymentLink  String?
  codPaymentId    String?
  placedAt        DateTime @default(now())
  paidAt          DateTime?
  transportPaidAt DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  returnedAt      DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           OrderItem[]
  statusLogs      OrderStatusLog[]
  shipments       Shipment[]
  transactions    Transaction[]
  returns         Return[]
  printJobs       PrintJob[]
  notifications   Notification[]
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  title       String
  sku         String?
  quantity    Int
  unitPrice   Float
  unitCost    Float
  total       Float
  createdAt   DateTime @default(now())
}

model OrderStatusLog {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus  String?
  toStatus    String
  reason      String?
  actor       String?  // userId o "system" o "shopify"
  metadata    String?  // JSON serializado
  createdAt   DateTime @default(now())
}

// ============================================================
// Sección 6: Pagos y Pasarelas
// ============================================================

model Transaction {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider      String   // WOMPI | PAYU | MERCADOPAGO | EPAYCO | BOLD
  type          String   // TRANSPORT | ORDER_PAYMENT
  amount        Float
  currency      String   @default("COP")
  status        String   @default("PENDING") // PENDING | APPROVED | DECLINED | REFUNDED
  reference     String?  @unique
  providerTxId  String?
  paymentUrl    String?
  rawResponse   String?  // JSON serializado
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// Sección 5: Logística, Guías y Tracking
// ============================================================

model Shipment {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier       String?  // SERVIENTREGA | ENVIA | INTERRAPIDISIMO | ...
  guideNumber   String?  @unique
  mastershopId  String?
  status        String   @default("CREATED") // CREATED | PRINTED | IN_TRANSIT | DELIVERED | RETURNED
  pdfUrl        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trackingEvents TrackingEvent[]
}

model TrackingEvent {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status      String
  message     String?
  city        String?
  occurredAt  DateTime
  createdAt   DateTime @default(now())
}

model PrintJob {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  guideNumber String?
  status      String   @default("QUEUED") // QUEUED | SENT | PRINTED | FAILED
  printer     String?
  attempts    Int      @default(0)
  error       String?
  queuedAt    DateTime @default(now())
  sentAt      DateTime?
  printedAt   DateTime?
}

// ============================================================
// Sección 10: Devoluciones
// ============================================================

model Return {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  reason      String?
  city        String?
  lostValue   Float    @default(0)
  status      String   @default("RECEIVED") // RECEIVED | INSPECTED | RESTOCKED | DISCARDED
  createdAt   DateTime @default(now())
}

// ============================================================
// Sección 8: Costos (para rentabilidad)
// ============================================================

model CostEntry {
  id          String   @id @default(cuid())
  category    String   // PRODUCT | SHIPPING | ADVERTISING | OPERATION
  description String
  amount      Float
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
}

// ============================================================
// Sección 13: Notificaciones y Alertas
// ============================================================

model Notification {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  channel     String   // DASHBOARD | WHATSAPP | EMAIL
  type        String   // INFO | WARNING | ERROR | SUCCESS
  title       String
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Alert {
  id          String   @id @default(cuid())
  type        String   // COD_UNPAID | GUIDE_ERROR | HIGH_RETURN | LOW_INVENTORY | SALES_DROP
  severity    String   @default("WARNING") // INFO | WARNING | CRITICAL
  entity      String?  // orderId, productId, etc.
  message     String
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
}

// ============================================================
// Sección 14: Auditoría
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?
  ip          String?
  metadata    String?  // JSON serializado
  createdAt   DateTime @default(now())
}

// ============================================================
// Configuración de Integraciones (credenciales)
// ============================================================

model IntegrationSetting {
  id          String   @id @default(cuid())
  provider    String   @unique // SHOPIFY | MASTERSHOP | WOMPI | PAYU | MERCADOPAGO | EPAYCO | BOLD | WHATSAPP | EMAIL
  config      String   // JSON serializado (apiKey, secret, etc.)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// Webhook Logs (auditoría de webhooks entrantes)
// ============================================================

model WebhookLog {
  id           String   @id @default(cuid())
  source       String   // shopify | payments | mastershop
  provider     String?  // SHOPIFY | WOMPI | MASTERSHOP | ...
  event        String?  // event type (orders/create, payment.approved, etc.)
  signature    String?  // signature header value (HMAC)
  payload      String   // raw body (JSON string)
  headers      String?  // JSON serialized headers
  ip           String?
  status       String   @default("PENDING") // PENDING | PROCESSED | FAILED | DUPLICATE
  result       String?  // JSON serialized result of processing
  error        String?  // error message if failed
  receivedAt   DateTime @default(now())
  processedAt  DateTime?
}

// ============================================================
// Sección 12: IA Insights
// ============================================================

model AiInsight {
  id          String   @id @default(cuid())
  type        String   // SALES_PREDICTION | ANOMALY | MONTHLY_SUMMARY | PRODUCT_ANALYSIS
  title       String
  content     String   // markdown
  metadata    String?  // JSON serializado
  createdAt   DateTime @default(now())
}
